# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_IDS=1482383137336983634

# Tastytrade OAuth Credentials
# 1. Create an OAuth app at tastytrade.com -> My Profile -> OAuth Applications
# 2. Generate a refresh token via Manage -> Create Grant
TT_CLIENT_SECRET=your_client_secret_here
TT_REFRESH_TOKEN=your_refresh_token_here
TT_ACCOUNT_NUMBER=your_account_number_here

# Risk Management (adjustable via Discord commands too)
RISK_PER_TRADE_PCT=1.0
STOP_LOSS_PCT=25.0
TAKE_PROFIT_PCT=30.0

# Exit mode: "auto" = OTOCO with fixed take-profit, "manual" = stop-loss only, sell on trim alert
EXIT_MODE=manual

# Optional: separate channel(s) for trim/profit/sell alerts (comma-separated)
# If empty, trim alerts are detected in the same alert channels
PROFIT_CHANNEL_IDS=

# Paper trading mode (set to false for live trading)
PAPER_TRADE=true
